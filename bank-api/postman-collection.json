            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceUserId\": \"{{userId}}\",\n  \"targetUserId\": \"{{userId2}}\",\n  \"amount\": 1000.00,\n  \"type\": \"THIRD_PARTY\",\n  \"metadata\": {\n    \"provider\": \"PayPal\",\n    \"reference\": \"PP-98765\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["transfers"]
            }
          }
        },
        {
          "name": "Buscar Transferencia por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Transferencia encontrada', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('amount');",
                  "    pm.expect(body).to.have.property('type');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transfers/{{transferId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transfers", "{{transferId}}"]
            }
          }
        },
        {
          "name": "Buscar Transferencias por Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Respuesta es un array', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transfers/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transfers", "user", "{{userId}}"]
            }
          }
        },

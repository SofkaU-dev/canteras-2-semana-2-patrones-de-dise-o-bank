            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceUserId\": \"{{userId}}\",\n  \"targetUserId\": \"{{userId2}}\",\n  \"amount\": 200.00,\n  \"type\": \"ATM\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["transfers"]
            }
          }
        },
        {
          "name": "Crear Transferencia CHEQUE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceUserId\": \"{{userId}}\",\n  \"targetUserId\": \"{{userId2}}\",\n  \"amount\": 500.00,\n  \"type\": \"CHEQUE\",\n  \"metadata\": {\n    \"chequeNumber\": \"CHQ-001234\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["transfers"]
            }
          }
        },
        {
          "name": "Crear Transferencia THIRD_PARTY",
